<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />

<title>Particle Demo</title>

<style>
:root {
  --bg: #1b1b1b;
  --panel: #222;
  --border: #333;
  --text: #888;
}

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  padding: 0;
  width: 100%;
  min-height: 100%;
  background: var(--bg);
  font-family: Inter, system-ui, sans-serif;
  overflow: hidden;
}

body {
  display: flex;
  align-items: center;
  justify-content: center;
}

#app {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  padding: 24px;
}

#game-shell {
  width: min(800px, 100vw - 48px);
  height: min(800px, 100vw - 48px);

  background: var(--panel);

  border: 1px solid var(--border);
  border-radius: 14px;

  overflow: hidden;

  box-shadow:
    0 10px 30px rgba(0,0,0,0.35),
    inset 0 0 0 1px rgba(255,255,255,0.02);

  position: relative;
}

canvas {
  width: 100%;
  height: 100%;
  display: block;
  background: black;
}

#loading {
  position: absolute;
  inset: 0;

  display: flex;
  align-items: center;
  justify-content: center;

  color: white;
  font-size: 14px;
  letter-spacing: 0.04em;

  background: rgba(0,0,0,0.65);
  backdrop-filter: blur(2px);

  z-index: 10;
}

#footer {
  color: var(--text);
  font-size: 12px;
  opacity: 0.75;
  user-select: none;
}

#footer a {
  color: inherit;
  text-decoration: none;
}

#footer a:hover {
  opacity: 1;
}
</style>
</head>

<body>

<div id="app">

  <div id="game-shell">

    <div id="loading">
      Loading...
    </div>

    <canvas
      id="canvas"
      oncontextmenu="event.preventDefault()"
      tabindex="-1">
    </canvas>

  </div>

  <div id="footer">
    powered by
    <a href="https://emscripten.org/" target="_blank">
      emscripten
    </a>
  </div>

</div>

<script>
const canvas = document.getElementById("canvas");
const loading = document.getElementById("loading");

function resizeCanvas() {

  const rect =
    canvas.getBoundingClientRect();

  const dpr =
    window.devicePixelRatio || 1;

  const width =
    Math.round(rect.width * dpr);

  const height =
    Math.round(rect.height * dpr);

  if (
    canvas.width !== width ||
    canvas.height !== height
  ) {
    canvas.width = width;
    canvas.height = height;
  }
}

window.addEventListener(
  "resize",
  resizeCanvas
);

var Module = {

  canvas,

  print(...args) {
    console.log(...args);
  },

  setStatus(text) {

    console.log(text);

    if (
      text.includes("All downloads complete") ||
      text === ""
    ) {
      loading.style.display = "none";
    }
  },

  monitorRunDependencies(left) {

    if (left === 0) {
      loading.style.display = "none";
    }
  },

  onRuntimeInitialized() {
    resizeCanvas();
  }
};

canvas.addEventListener(
  "webglcontextlost",
  (e) => {
    e.preventDefault();
    alert(
      "WebGL context lost. Reload required."
    );
  },
  false
);
</script>

<script async src="index.js"></script>

</body>
</html>